#!/usr/bin/env bash
set -euo pipefail

source "${BASHIO_LIB:-/usr/lib/bashio/bashio}"

readonly BOOTSTRAP_DIR="/usr/share/postgresql/bootstrap"
readonly ADMIN_DB="postgres"
readonly PSQL_APPLY_FILE="${PSQL_APPLY_FILE:-/usr/bin/psql-apply-file}"
readonly PSQL_BIN="${PSQL_BIN:-psql}"
readonly RUNUSER_BIN="${RUNUSER_BIN:-runuser}"

sql_literal() {
  local value="${1//\'/\'\'}"
  printf "'%s'" "${value}"
}

sql_ident() {
  local value="${1//\"/\"\"}"
  printf '"%s"' "${value}"
}

join_privileges() {
  local raw="$1"
  local -a items=()
  local item
  mapfile -t items <<< "${raw}"

  local joined=""
  for item in "${items[@]}"; do
    [[ -z "${item}" ]] && continue
    if [[ -n "${joined}" ]]; then
      joined+=", "
    fi
    joined+="${item}"
  done

  printf "%s" "${joined}"
}

psql_exec() {
  local db_name="$1"
  local sql="$2"

  "${RUNUSER_BIN}" -u postgres -- "${PSQL_BIN}" \
    --no-psqlrc \
    --quiet \
    --set=ON_ERROR_STOP=1 \
    --host /run/postgresql \
    --username postgres \
    --dbname "${db_name}" \
    --command "${sql}"
}

psql_scalar() {
  local db_name="$1"
  local sql="$2"

  "${RUNUSER_BIN}" -u postgres -- "${PSQL_BIN}" \
    --no-psqlrc \
    --quiet \
    --tuples-only \
    --no-align \
    --set=ON_ERROR_STOP=1 \
    --host /run/postgresql \
    --username postgres \
    --dbname "${db_name}" \
    --command "${sql}"
}

psql_query_file() {
  local db_name="$1"
  local sql_file="$2"
  shift 2

  "${RUNUSER_BIN}" -u postgres -- "${PSQL_BIN}" \
    --no-psqlrc \
    --quiet \
    --tuples-only \
    --no-align \
    --field-separator=$'\t' \
    --set=ON_ERROR_STOP=1 \
    --host /run/postgresql \
    --username postgres \
    --dbname "${db_name}" \
    --file "${sql_file}" \
    "$@"
}

db_owner() {
  local db_name="$1"
  psql_scalar "${ADMIN_DB}" "SELECT pg_get_userbyid(datdba) FROM pg_database WHERE datname = ${db_name};"
}

apply_file() {
  local database="$1"
  local file="$2"
  shift 2
  "${PSQL_APPLY_FILE}" "${database}" "${file}" "$@"
}

declare -A declared_memberships=()
declare -A declared_database_privileges=()
declare -A declared_schema_privileges=()
declare -A emitted_drift_warnings=()

emit_drift_warnings() {
  local database="$1"
  local current_database_owner="$2"
  local current_schema_owner="$3"
  shift 3

  while IFS=$'\t' read -r object_type object_context subject_role extra_privilege; do
    [[ -z "${object_type:-}" ]] && continue

    case "${object_type}" in
      membership)
        key="${object_context}"$'\t'"${subject_role}"
        if [[ -z "${declared_memberships[${key}]:-}" ]]; then
          warning="postgres drift: object_type=${object_type} context=${object_context} subject_role=${subject_role} extra_privilege=${extra_privilege}"
          if [[ -z "${emitted_drift_warnings[${warning}]:-}" ]]; then
            emitted_drift_warnings["${warning}"]=1
            bashio::log.warning "${warning}"
          fi
        fi
        ;;
      database)
        [[ "${object_context}" != "${database}" ]] && continue
        [[ "${subject_role}" == "${current_database_owner}" ]] && continue
        key="${object_context}"$'\t'"${subject_role}"$'\t'"${extra_privilege}"
        if [[ -z "${declared_database_privileges[${key}]:-}" ]]; then
          warning="postgres drift: object_type=${object_type} context=${object_context} subject_role=${subject_role} extra_privilege=${extra_privilege}"
          if [[ -z "${emitted_drift_warnings[${warning}]:-}" ]]; then
            emitted_drift_warnings["${warning}"]=1
            bashio::log.warning "${warning}"
          fi
        fi
        ;;
      schema)
        [[ "${object_context}" != "public" ]] && continue
        [[ "${subject_role}" == "${current_schema_owner}" ]] && continue
        key="${object_context}"$'\t'"${subject_role}"$'\t'"${extra_privilege}"
        if [[ -z "${declared_schema_privileges[${key}]:-}" ]]; then
          warning="postgres drift: database=${database} object_type=${object_type} context=${object_context} subject_role=${subject_role} extra_privilege=${extra_privilege}"
          if [[ -z "${emitted_drift_warnings[${warning}]:-}" ]]; then
            emitted_drift_warnings["${warning}"]=1
            bashio::log.warning "${warning}"
          fi
        fi
        ;;
    esac
  done
}

if [[ "$(bashio::config 'roles|length')" -gt 0 ]]; then
  for role in $(bashio::config 'roles|keys'); do
    username="$(bashio::config "roles[${role}].username")"
    login="false"
    password=""

    if bashio::config.exists "roles[${role}].login"; then
      login="$(bashio::config "roles[${role}].login")"
    fi
    if bashio::config.exists "roles[${role}].password"; then
      password="$(bashio::config "roles[${role}].password")"
    fi

    apply_file "${ADMIN_DB}" "${BOOTSTRAP_DIR}/roles.sql" \
      -v role_name="${username}" \
      -v role_login="${login}" \
      -v role_password="${password}"
  done
fi

if [[ "$(bashio::config 'memberships|length')" -gt 0 ]]; then
  for membership in $(bashio::config 'memberships|keys'); do
    group_name="$(bashio::config "memberships[${membership}].group")"
    member_name="$(bashio::config "memberships[${membership}].member")"
    declared_memberships["${group_name}"$'\t'"${member_name}"]=1

    apply_file "${ADMIN_DB}" "${BOOTSTRAP_DIR}/memberships.sql" \
      -v group_name="${group_name}" \
      -v member_name="${member_name}"
  done
fi

if [[ "$(bashio::config 'databases|length')" -gt 0 ]]; then
  for database in $(bashio::config 'databases|keys'); do
    db_name="$(bashio::config "databases[${database}].name")"
    db_owner_name=""

    if bashio::config.exists "databases[${database}].owner"; then
      db_owner_name="$(bashio::config "databases[${database}].owner")"
    fi

    db_name_literal="$(sql_literal "${db_name}")"
    if [[ -z "$(psql_scalar "${ADMIN_DB}" "SELECT 1 FROM pg_database WHERE datname = ${db_name_literal};")" ]]; then
      if [[ -n "${db_owner_name}" ]]; then
        psql_exec "${ADMIN_DB}" "CREATE DATABASE $(sql_ident "${db_name}") OWNER $(sql_ident "${db_owner_name}");"
      else
        psql_exec "${ADMIN_DB}" "CREATE DATABASE $(sql_ident "${db_name}");"
      fi
    fi

    apply_file "${ADMIN_DB}" "${BOOTSTRAP_DIR}/databases.sql" \
      -v db_name="${db_name}" \
      -v db_owner="${db_owner_name}"
  done
fi

if [[ "$(bashio::config 'databases|length')" -gt 0 ]]; then
  for database in $(bashio::config 'databases|keys'); do
    db_name="$(bashio::config "databases[${database}].name")"
    apply_file "${db_name}" "${BOOTSTRAP_DIR}/extensions.sql"
  done
fi

if [[ "$(bashio::config 'databases|length')" -gt 0 ]]; then
  for database in $(bashio::config 'databases|keys'); do
    db_name="$(bashio::config "databases[${database}].name")"
    current_owner="$(db_owner "$(sql_literal "${db_name}")")"
    current_owner="${current_owner//$'\n'/}"
    apply_file "${db_name}" "${BOOTSTRAP_DIR}/schemas.sql" \
      -v db_owner="${current_owner}"
  done
fi

if [[ "$(bashio::config 'grants|length')" -gt 0 ]]; then
  for grant in $(bashio::config 'grants|keys'); do
    grant_db="$(bashio::config "grants[${grant}].database")"
    grant_role="$(bashio::config "grants[${grant}].role")"
    grant_privileges_raw="$(bashio::config "grants[${grant}].privileges")"
    grant_privileges="$(join_privileges "${grant_privileges_raw}")"
    grant_db_owner="$(db_owner "$(sql_literal "${grant_db}")")"
    grant_db_owner="${grant_db_owner//$'\n'/}"
    declared_database_privileges["${grant_db}"$'\t'"${grant_role}"$'\t'CONNECT]=1
    declared_schema_privileges["public"$'\t'"${grant_role}"$'\t'USAGE]=1

    psql_exec "${grant_db}" "$(cat <<EOF
ALTER DEFAULT PRIVILEGES FOR ROLE $(sql_ident "${grant_db_owner}") IN SCHEMA public GRANT ${grant_privileges} ON TABLES TO $(sql_ident "${grant_role}");
EOF
)"

    apply_file "${grant_db}" "${BOOTSTRAP_DIR}/grants.sql" \
      -v grant_role="${grant_role}" \
      -v grant_privileges="${grant_privileges}"
  done
fi

if [[ "$(bashio::config 'memberships|length')" -gt 0 ]]; then
  emit_drift_warnings "${ADMIN_DB}" "" "" < <(
    psql_query_file "${ADMIN_DB}" "${BOOTSTRAP_DIR}/drift.sql" \
      -v include_memberships=1
  )
fi

if [[ "$(bashio::config 'databases|length')" -gt 0 ]]; then
  for database in $(bashio::config 'databases|keys'); do
    db_name="$(bashio::config "databases[${database}].name")"
    current_database_owner="$(db_owner "$(sql_literal "${db_name}")")"
    current_database_owner="${current_database_owner//$'\n'/}"
    current_schema_owner="$(psql_scalar "${db_name}" "SELECT pg_get_userbyid(nspowner) FROM pg_namespace WHERE nspname = 'public';")"
    current_schema_owner="${current_schema_owner//$'\n'/}"
    emit_drift_warnings "${db_name}" "${current_database_owner}" "${current_schema_owner}" < <(
      psql_query_file "${db_name}" "${BOOTSTRAP_DIR}/drift.sql" \
        -v include_database_privileges=1 \
        -v include_schema_privileges=1
    )
  done
fi
