#!/usr/bin/env bash
set -euo pipefail

source "${BASHIO_LIB:-/usr/lib/bashio/bashio}"

readonly DATA_DIR="${POSTGRES_DATA_DIR:-/data/postgres}"
readonly RUNTIME_DIR="${POSTGRES_RUNTIME_DIR:-/run/postgresql}"
readonly CONF_FILE="${DATA_DIR}/postgresql.conf"
readonly HBA_FILE="${DATA_DIR}/pg_hba.conf"
readonly IDENT_FILE="${DATA_DIR}/pg_ident.conf"

mkdir -p "${DATA_DIR}" "${RUNTIME_DIR}"

runtime_uid="${POSTGRES_RUNTIME_UID:-}"
runtime_gid="${POSTGRES_RUNTIME_GID:-}"
runtime_supplementary_gids_raw="${POSTGRES_RUNTIME_SUPPLEMENTARY_GIDS:-}"
if [[ -z "${runtime_uid}" || -z "${runtime_gid}" ]]; then
  runtime_uid="$(id -u postgres)"
  runtime_gid="$(id -g postgres)"
fi

if [[ -z "${runtime_supplementary_gids_raw}" ]]; then
  runtime_supplementary_gids_raw="$(id -G postgres 2>/dev/null || true)"
fi

runtime_supplementary_gids=()
if [[ -n "${runtime_supplementary_gids_raw}" ]]; then
  read -r -a runtime_supplementary_gids <<< "${runtime_supplementary_gids_raw}"
fi

can_runtime_user_read() {
  local path="$1"
  local file_uid file_gid file_mode group_gid

  read -r file_uid file_gid file_mode < <(stat -c '%u %g %a' "${path}")

  if [[ "${runtime_uid}" == "${file_uid}" ]]; then
    (( 8#${file_mode} & 0400 )) && return 0
  fi

  if [[ "${runtime_gid}" == "${file_gid}" ]]; then
    (( 8#${file_mode} & 0040 )) && return 0
  fi

  for group_gid in "${runtime_supplementary_gids[@]}"; do
    if [[ "${group_gid}" == "${file_gid}" ]]; then
      (( 8#${file_mode} & 0040 )) && return 0
    fi
  done

  (( 8#${file_mode} & 0004 )) && return 0

  return 1
}

validate_private_key_file() {
  local path="$1"
  local file_uid file_gid file_mode

  read -r file_uid file_gid file_mode < <(stat -c '%u %g %a' "${path}")

  if [[ "${file_uid}" != "${runtime_uid}" ]]; then
    return 1
  fi

  case "${file_mode}" in
    400|600)
      ;;
    *)
      return 1
      ;;
  esac

  return 0
}

ssl_enabled="$(bashio::config 'ssl.enabled')"
ssl_setting="off"
ssl_cert_file=""
ssl_key_file=""

if bashio::var.true "${ssl_enabled}"; then
  ssl_cert_file="$(bashio::config 'ssl.certfile')"
  ssl_key_file="$(bashio::config 'ssl.keyfile')"

  if [[ -z "${ssl_cert_file}" || -z "${ssl_key_file}" ]]; then
    bashio::exit.nok "ssl.enabled requires ssl.certfile and ssl.keyfile"
  fi

  can_runtime_user_read "${ssl_cert_file}" || bashio::exit.nok "ssl.certfile must be readable by the postgres runtime user"
  validate_private_key_file "${ssl_key_file}" || bashio::exit.nok "ssl.keyfile must be owned by the postgres runtime user and have mode 400 or 600"

  ssl_setting="on"
fi

allowlist=()
allowlist_count="$(bashio::config 'network.allowlist|length')"
if [[ "${allowlist_count}" -gt 0 ]]; then
  for idx in $(bashio::config 'network.allowlist|keys'); do
    cidr="$(bashio::config "network.allowlist[${idx}]")"
    [[ -n "${cidr}" ]] && allowlist+=("${cidr}")
  done
else
  allowlist+=("127.0.0.1/32" "::1/128")
fi

{
  printf "listen_addresses = '*'\n"
  printf "unix_socket_directories = '%s'\n" "${RUNTIME_DIR}"
  printf "data_directory = '%s'\n" "${DATA_DIR}"
  printf "hba_file = '%s'\n" "${HBA_FILE}"
  printf "ident_file = '%s'\n" "${IDENT_FILE}"
  printf "ssl = %s\n" "${ssl_setting}"
  if bashio::var.true "${ssl_enabled}"; then
    printf "ssl_cert_file = '%s'\n" "${ssl_cert_file}"
    printf "ssl_key_file = '%s'\n" "${ssl_key_file}"
  fi
  printf "shared_preload_libraries = 'timescaledb'\n"
} > "${CONF_FILE}"

{
  printf "local all all trust\n"
  for cidr in "${allowlist[@]}"; do
    if bashio::var.true "${ssl_enabled}"; then
      printf "hostssl all all %s scram-sha-256\n" "${cidr}"
    else
      printf "host all all %s scram-sha-256\n" "${cidr}"
    fi
  done
} > "${HBA_FILE}"

: > "${IDENT_FILE}"
